#!/usr/bin/env bash

# Pre-commit hook: ruff format + lint for Python files in src/ and tests/

PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(src|tests)/.*\.py$')

if [ -z "$PYTHON_FILES" ]; then
    exit 0
fi

resolve_ruff() {
    if [ -f ".venv/bin/ruff" ]; then
        printf '%s\n' ".venv/bin/ruff"
        return 0
    fi
    if [ -f ".venv/Scripts/ruff.exe" ] && ! grep -qi microsoft /proc/version 2>/dev/null; then
        printf '%s\n' ".venv/Scripts/ruff.exe"
        return 0
    fi
    if [ -f ".venv/Scripts/ruff" ] && ! grep -qi microsoft /proc/version 2>/dev/null; then
        printf '%s\n' ".venv/Scripts/ruff"
        return 0
    fi
    if command -v ruff &>/dev/null; then
        command -v ruff
        return 0
    fi
    return 1
}

if ! RUFF=$(resolve_ruff); then
    echo "WARNING: ruff not found in .venv or PATH — skipping Python format/lint checks"
    exit 0
fi

# Phase 1: Auto-format staged files and re-stage
echo "$PYTHON_FILES" | xargs "$RUFF" format
echo "$PYTHON_FILES" | xargs git add

# Phase 2: Lint (blocks commit on failure)
echo "$PYTHON_FILES" | xargs "$RUFF" check
if [ $? -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: ruff lint errors found (see above)"
    exit 1
fi
