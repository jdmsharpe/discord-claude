# Environment variables example file - to be used as a template for .env file
BOT_TOKEN=your_value_here
GUILD_IDS=your_value_here
ANTHROPIC_API_KEY=your_value_here

# MCP Presets (optional) — configure remote MCP servers for the Claude cog
# Provide presets as inline JSON or as a path to a JSON file (both are additive, no duplicate names allowed)
# ANTHROPIC_MCP_PRESETS_JSON=
# ANTHROPIC_MCP_PRESETS_PATH=config/mcp-presets.json

# Optional: Show per-request cost and daily cost embeds in /claude chat responses (default: true; accepts true/1/yes)
# SHOW_COST_EMBEDS=true

# Optional: Override where per-user memory files are stored (default: ./memories)
# MEMORIES_DIR=./memories
